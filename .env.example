# TradeStrategy environment configuration
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The Streamlit app itself runs with empty values for everything below —
# the screener and Lookup tab use yfinance / SEC public endpoints, no
# auth required. The variables here only matter for specific subsystems.
# ---------------------------------------------------------------------

# === Telegram daily brief (send_brief.py) ===================================
# Only needed if you run send_brief.py to push daily picks to Telegram.
# Create a bot via @BotFather, then chat with it to get your chat ID via
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# === SEC EDGAR user-agent ===================================================
# The SEC's EDGAR API requires a real user-agent with contact info for
# every request. Pattern: "AppName ContactName email@domain".
# Default values exist in `core/sec_edgar.py` and `core/edgar_rss.py` but
# you should override them with your own contact info before deploying.
SEC_USER_AGENT=TradeStrategy YourName your.email@example.com


# === Optional: paid data sources (future) ==================================
# Phase 5+ allows swapping yfinance for paid providers. Set credentials
# here when those providers are implemented. None of these are read yet.
#
# POLYGON_API_KEY=
# IEX_CLOUD_TOKEN=
# ALPHA_VANTAGE_KEY=
